    APP_NAME=MarbellaFacil
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

# IA Chat (Groq)
GROQ_API_KEY=

# Registro de errores
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# CONEXIÓN BASE DE DATOS
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=marbella_facil
DB_USERNAME=
DB_PASSWORD=

# CONFIGURACIÓN DE DRIVERS
SESSION_DRIVER=file
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_LIFETIME=120

# Configuración de Correo (log para desarrollo)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hola@marbellafacil.com"
MAIL_FROM_NAME="${APP_NAME}"

# Otros
BCRYPT_ROUNDS=12
VITE_APP_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
