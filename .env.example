# Variables usadas por docker-compose.yml
# Copia este fichero a .env y rellena los valores reales:
#   cp .env.example .env

APP_KEY=base64:TU_APP_KEY_AQUI
GROQ_API_KEY=tu_groq_api_key

# Backend (Laravel) - URL del servidor donde corre el backend
APP_URL=http://TU_IP_O_DOMINIO:8000

# Base de datos
DB_HOST=IP_DEL_SERVIDOR_MYSQL
DB_PORT=3306
DB_DATABASE=marbella_facil
DB_USERNAME=desarrollador
DB_PASSWORD=tu_password_mysql

# Frontend (Vite build-time)
# Usar /api para que Nginx haga el proxy al backend automáticamente
VITE_API_URL=/api
